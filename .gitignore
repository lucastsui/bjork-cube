# Secrets — never commit
.env

# Python
__pycache__/
*.pyc

# Runtime scratch
outputs/
uploads/

# Large sample audio (users supply their own style clips)
*.mp3

# Per-user runtime data (personal pins; regenerated at runtime)
landmarks.json

# In-project Magenta model weights (~13 GB: checkpoints + models + resources).
# Vendored model CODE (./magenta_rt) IS committed; the WEIGHTS are not — see
# README "Installation" for the one-time copy/download.
magenta_home/

# Local virtualenv (a fresh clone makes its own: python -m venv .venv)
.venv/

# Note: groove_dist/groove_library.json and vocab.json (embedding cache)
# ARE committed so the app is runnable straight from a clone.

# Editor backups
*.bak

# Tempo beat references (133MB, reproducible via tools/make_tempo_beats.py)
tempo_refs/
.DS_Store

# Scratch bounce demos
groove-swing-*.wav

*.zip
agr_txt/*.agr
audience_marks.json
